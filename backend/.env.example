# Configuración del servidor
PORT=3002

# Configuración de Base de Datos PostgreSQL
# Establece USE_PG=true para usar PostgreSQL en lugar de JSON
USE_PG=false
PG_HOST=localhost
PG_PORT=5432
PG_USER=postgres
PG_PASS=tu-contraseña-postgres
PG_DB=inces

# JWT Secret - cambia esto en producción
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# URL del Frontend
FRONTEND_URL=http://localhost:5173

# Configuración de Email (SMTP)
# Ejemplo para Gmail:
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=tu-correo@gmail.com
# SMTP_PASS=tu-contraseña-de-app
# EMAIL_FROM=INCES <no-reply@inces.gob.ve>

# Ejemplo para Outlook:
# SMTP_HOST=smtp.office365.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=tu-correo@tu-dominio.com
# SMTP_PASS=tu-contraseña
# EMAIL_FROM=INCES <no-reply@tu-dominio.com>

# Para pruebas locales (sin configurar SMTP), el sistema usará Ethereal
# Los enlaces de prueba aparecen en la consola del servidor
