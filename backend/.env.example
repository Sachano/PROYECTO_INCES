# Configuración del servidor
PORT=3002

# Usa JSON local para desarrollo. Establece USE_PG=true solo si PostgreSQL está configurado.
USE_PG=false
PG_HOST=localhost
PG_PORT=5432
PG_USER=postgres
PG_PASS=tu-contraseña-postgres
PG_DB=inces

# JWT Secret - cambia esto en producción
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# URL del Frontend local
FRONTEND_URL=http://localhost:5173

# Email SMTP opcional
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=INCES <no-reply@inces.local>

